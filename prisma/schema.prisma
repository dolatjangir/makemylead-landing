// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model DemoRequest {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  message   String?  @db.VarChar(2000)
  status    String   @default("pending")
  source    String   @default("chatbot")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("demo_requests")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.VarChar(2000)
  createdAt DateTime @default(now())
}

model ContactSupport {
  id            String   @id @default(cuid())
  name          String
  email         String
  subject       String
  message       String   @db.VarChar(2000)
  inquiryType   String?  @db.VarChar(255)
  priority      String?  @db.VarChar(100)
  supportMethod String?  @db.VarChar(100)
  preferredTime String?  @db.VarChar(100)
  createdAt     DateTime @default(now())
}

model SeoEntry {
  id                 String   @id @default(uuid())
  pageName           String
  slug               String   @unique
  url                String   @unique
  metaTitle          String
  metaDescription    String   @db.VarChar(1000)
  keywords           String   @db.VarChar(1000) // Stored as JSON string array
  canonicalUrl       String?  @db.VarChar(500)
  ogTitle            String?  @db.VarChar(255)
  ogDescription      String?  @db.VarChar(1000)
  ogImage            String?  @db.VarChar(500)
  twitterTitle       String?  @db.VarChar(255)
  twitterDescription String?  @db.VarChar(1000)
  twitterImage       String?  @db.VarChar(500)
  seoScore           Int      @default(0)
  status             Status   @default(draft)
  indexable          Boolean  @default(true)
  lastModified       DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@index([status])
  @@index([seoScore])
  @@map("seo_entries")
}

model Login {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Broker {
  id             String   @id @default(uuid())
  name           String
  image          String?
  company        String
  role           String
  location       String   @default("")
  description    String   @default("") @db.VarChar(2000)
  email          String
  phone          String   @default("")
  experience     String   @default("")
  specialization Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
  @@index([name])
  @@map("brokers")
}

model Requirement {
  id              String  @id @default(cuid())
  requirementType String // buy | rent
  propertyType    String
  propertySubtype String
  city            String
  location        String
  minPrice        Int
  maxPrice        Int
  name            String
  contactNumber   String
  email           String
  description     String?

  createdAt DateTime @default(now())
}

model BrokerApplication {
  id              String  @id @default(uuid())
  fullName        String
  email           String
  phone           String
  companyName     String
  role            String
  experience      String
  dealsClosed     String?
  location        String
  specializations String  @default("[]") // JSON array as string
  description     String  @db.Text
  profileImage    String? // URL to stored image

  status ApplicationStatus @default(pending)

  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?   @db.Text

  @@index([status])
  @@index([email])
  @@index([submittedAt])
  @@map("broker_applications")
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

enum Role {
  ADMIN
  USER
}

enum Status {
  published
  draft
}
